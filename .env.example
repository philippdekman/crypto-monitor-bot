# ── Telegram ──────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
ADMIN_USER_IDS=123456789                 # Ваш Telegram user ID (через запятую для нескольких)

# ── Blockchain API keys (free tiers) ────────────────────
ETHERSCAN_API_KEY=your_etherscan_key     # https://etherscan.io/myapikey (бесплатно)
BSCTRACE_API_KEY=                        # https://meganode.nodereal.io (бесплатно, для BSC)
TRONGRID_API_KEY=your_trongrid_key       # https://www.trongrid.io (бесплатно)

# ── HD Wallet (BIP39 mnemonic) ──────────────────────────
# ВАЖНО: Сгенерируйте новую мнемонику! Не используйте свой основной кошелёк!
# Генератор: python -c "from hdwallet import HDWallet; from hdwallet.utils import generate_mnemonic; print(generate_mnemonic(language='english', strength=256))"
HD_WALLET_MNEMONIC=word1 word2 word3 word4 word5 word6 word7 word8 word9 word10 word11 word12

# ── Monitoring settings ─────────────────────────────────
MONITOR_INTERVAL_SECONDS=120             # Как часто проверять адреса (в секундах)
DATABASE_PATH=data/bot.db                # Путь к базе данных SQLite
