# ── Telegram ──────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
ADMIN_USER_IDS=123456789                 # Ваш Telegram user ID (через запятую для нескольких)

# ── Blockchain API keys (optional, free tiers) ──────────
ETHERSCAN_API_KEY=                       # https://etherscan.io/myapikey (бесплатно)
TRONGRID_API_KEY=                        # https://www.trongrid.io (бесплатно)

# ── HD Wallet (BIP39 mnemonic) ──────────────────────────
# ВАЖНО: Сгенерируйте новую мнемонику! Не используйте свой основной кошелёк!
HD_WALLET_MNEMONIC=word1 word2 word3 word4 word5 word6 word7 word8 word9 word10 word11 word12

# ── Database (PostgreSQL) ───────────────────────────────
# Railway автоматически подставляет DATABASE_URL при подключении PostgreSQL add-on
DATABASE_URL=postgresql://user:pass@host:5432/railway

# ── Monitoring settings ─────────────────────────────────
MONITOR_INTERVAL_SECONDS=120             # Как часто проверять адреса (в секундах)
